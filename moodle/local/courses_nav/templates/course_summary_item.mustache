{{!
@template local_courses_nav/course_summary_item

Renders a single course as a summary item matching block_myoverview/view-summary structure.
This template is rendered per-course by JS.

Example context (json):
{
"id": 2,
"fullname": "Course name",
"viewurl": "https://moodlesite/course/view.php?id=2",
"courseimage": "https://moodlesite/pluginfile/123/course/overviewfiles/123.jpg",
"summary": "This is the course summary",
"hasprogress": true,
"progress": 10,
"visible": true,
"showcoursecategory": true,
"coursecategory": "Category 1"
}
}}
<div class="course-summaryitem list-group-item course-listitem border-start-0 border-end-0 border-top-0 px-2 rounded-0"
    role="listitem" data-region="course-content" data-course-id="{{{id}}}">
    <div class="row">
        <div class="col-md-2 d-flex align-items-center mb-sm-3 mb-md-0">
            <a href="{{viewurl}}" tabindex="-1" class="mw-100 w-100">
                <div class="summary-image rounded mw-100" style='background-image: url("{{{courseimage}}}");'>
                    <span class="sr-only">{{fullname}}</span>
                </div>
            </a>
        </div>
        <div class="col-md-9 d-flex flex-column">
            <a href="{{viewurl}}" class="aalink coursename">
                {{{fullname}}}
            </a>
            {{#showcoursecategory}}
            <span class="categoryname">
                {{#coursecategory}}
                {{{coursecategory}}}
                {{/coursecategory}}
            </span>
            {{/showcoursecategory}}
            {{^visible}}
            <div class="d-flex flex-wrap">
                <span class="badge bg-info text-white">{{#str}}hiddenfromstudents{{/str}}</span>
            </div>
            {{/visible}}
            {{#summary}}
            <div class="summary">
                {{{summary}}}
            </div>
            {{/summary}}
            {{#hasprogress}}
            <div class="text-muted muted d-flex flex-wrap mt-auto">
                <div class="progress-text">
                    {{progress}}% complete
                </div>
            </div>
            {{/hasprogress}}
        </div>
        <div class="col-md-1 p-0 d-flex">
        </div>
    </div>
</div>