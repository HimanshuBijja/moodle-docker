{{!
@template local_analysis_dashboard/dashboard

Analysis Dashboard main page template.

Classes required for JS:
* none

Data attributes required for JS:
* data-region="analysis-dashboard"

Context variables required for this template:
* pagetitle - Page title string
* pagesubtitle - Page subtitle string
* has_widgets - Whether there are any widgets
* widgets - Array of widget objects (id, name, type)
* widgets_json - JSON-encoded widgets array
* no_widgets_message - Message when no widgets available

Example context (json):
{
"pagetitle": "Analysis Dashboard",
"pagesubtitle": "Site-wide analytics and statistics",
"has_widgets": true,
"widgets": [
{"id": "total_users", "name": "Total Users", "type": "counter"},
{"id": "total_courses", "name": "Total Courses", "type": "counter"},
{"id": "site_visits", "name": "Site Visits Over Time", "type": "line"}
],
"widgets_json": "[{\"id\":\"total_users\",\"name\":\"Total Users\",\"type\":\"counter\"}]",
"no_widgets_message": "No widgets are available for your role."
}
}}
<div data-region="analysis-dashboard" class="analysis-dashboard" role="main" aria-label="{{pagetitle}}">
    <div class="analysis-dashboard-header mb-4">
        <p class="text-muted">{{pagesubtitle}}</p>
    </div>

    {{#has_widgets}}
    <div class="analysis-dashboard-grid">
        {{#widgets}}
        {{> local_analysis_dashboard/widget_card}}
        {{/widgets}}
    </div>
    {{/has_widgets}}

    {{^has_widgets}}
    <div class="alert alert-info">
        {{no_widgets_message}}
    </div>
    {{/has_widgets}}
</div>

{{#js}}
require(['local_analysis_dashboard/dashboard'], function(Dashboard) {
Dashboard.init({{{widgets_json}}});
});
{{/js}}