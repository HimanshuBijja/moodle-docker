{{!
@template local_analysis_dashboard/course_report

Course-level analytics report template with Analytics/Feedback tab navigation.

Context variables required for this template:
* pagetitle - Page title string
* pagesubtitle - Page subtitle string
* courseid - Course ID
* coursename - Course full name
* has_widgets - Whether there are any widgets
* widgets - Array of widget objects (id, name, type)
* widgets_json - JSON-encoded widgets array
* no_widgets_message - Message when no widgets available
* tab_analytics_active - Boolean for analytics tab active
* tab_feedback_active - Boolean for feedback tab active
* tab_analytics_url - URL to analytics tab
* tab_feedback_url - URL to feedback tab
* has_feedback_forms - Whether there are feedback activities
* feedback_forms - Array of feedback form objects (id, name, has_comments)
* feedback_forms_json - JSON-encoded feedback forms
* feedback_section_title - Section title string
* feedback_section_desc - Section description string
* courseshortname - Course short name for export filenames

Example context (json):
{
"pagetitle": "Course Analytics",
"pagesubtitle": "Analytics for Introduction to Computing",
"courseid": 2,
"coursename": "Introduction to Computing",
"has_widgets": true,
"widgets": [
{"id": "enrollment_stats", "name": "Enrollment Stats", "type": "counter"}
],
"widgets_json": "[{\"id\":\"enrollment_stats\"}]",
"no_widgets_message": "No widgets are available for your role.",
"tab_analytics_active": true,
"tab_feedback_active": false,
"tab_analytics_url": "/local/analysis_dashboard/coursereport.php?id=2&tab=analytics",
"tab_feedback_url": "/local/analysis_dashboard/coursereport.php?id=2&tab=feedback",
"has_feedback_forms": true,
"feedback_forms": [{"id": 1, "name": "End of Course Survey", "has_comments": true}],
"feedback_forms_json": "[{\"id\":1,\"name\":\"End of Course Survey\",\"has_comments\":true}]",
"feedback_section_title": "Feedback Analysis",
"feedback_section_desc": "Response distribution across all feedback forms",
"courseshortname": "CS101"
}
}}
<div data-region="analysis-dashboard-course" class="analysis-dashboard" role="main" aria-label="{{pagetitle}}">
    <div class="analysis-dashboard-header mb-3">
        <p class="text-muted">{{pagesubtitle}}</p>
    </div>

    {{! === Horizontal Tab Navigation === }}
    <ul class="nav nav-tabs course-report-tabs mb-4" role="tablist">
        <li class="nav-item">
            <a class="nav-link {{#tab_analytics_active}}active{{/tab_analytics_active}}" href="{{tab_analytics_url}}"
                role="tab"
                aria-selected="{{#tab_analytics_active}}true{{/tab_analytics_active}}{{^tab_analytics_active}}false{{/tab_analytics_active}}">
                <i class="fa fa-chart-line mr-1" aria-hidden="true"></i>
                {{#str}}tab_analytics, local_analysis_dashboard{{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_feedback_active}}active{{/tab_feedback_active}}" href="{{tab_feedback_url}}"
                role="tab"
                aria-selected="{{#tab_feedback_active}}true{{/tab_feedback_active}}{{^tab_feedback_active}}false{{/tab_feedback_active}}">
                <i class="fa fa-comments mr-1" aria-hidden="true"></i>
                {{#str}}tab_feedback, local_analysis_dashboard{{/str}}
            </a>
        </li>
    </ul>

    {{! === Analytics Tab Content === }}
    {{#tab_analytics_active}}
    {{#has_widgets}}
    <div class="analysis-dashboard-grid">
        {{#widgets}}
        {{> local_analysis_dashboard/widget_card}}
        {{/widgets}}
    </div>
    {{/has_widgets}}

    {{^has_widgets}}
    <div class="alert alert-info">
        {{no_widgets_message}}
    </div>
    {{/has_widgets}}
    {{/tab_analytics_active}}

    {{! === Feedback Tab Content === }}
    {{#tab_feedback_active}}
    {{#has_feedback_forms}}
    <div class="feedback-analysis-section" data-region="feedback-analysis">
        <div class="feedback-analysis-header mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
                <div>
                    <h3 class="d-flex align-items-center">
                        <span class="feedback-section-icon mr-2">
                            <i class="fa fa-comments" aria-hidden="true"></i>
                        </span>
                        {{feedback_section_title}}
                    </h3>
                    <p class="text-muted mb-0">{{feedback_section_desc}}</p>
                </div>
                <div class="dropdown" data-region="feedback-export">
                    <button class="btn btn-outline-primary dropdown-toggle" type="button" id="feedbackExportDropdown"
                        data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        <i class="fa fa-download mr-1" aria-hidden="true"></i>
                        {{#str}}export_feedback, local_analysis_dashboard{{/str}}
                    </button>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="feedbackExportDropdown">
                        <a class="dropdown-item" href="#" data-export-format="csv">
                            <i class="fa fa-file-text-o mr-2" aria-hidden="true"></i>
                            {{#str}}export_csv, local_analysis_dashboard{{/str}}
                        </a>
                        <a class="dropdown-item" href="#" data-export-format="xlsx">
                            <i class="fa fa-file-excel-o mr-2" aria-hidden="true"></i>
                            {{#str}}export_excel, local_analysis_dashboard{{/str}}
                        </a>
                        <a class="dropdown-item" href="#" data-export-format="pdf">
                            <i class="fa fa-file-pdf-o mr-2" aria-hidden="true"></i>
                            {{#str}}export_pdf, local_analysis_dashboard{{/str}}
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {{! Per-Form Feedback Widgets }}
        <div class="feedback-forms-container">
            {{#feedback_forms}}
            <div class="feedback-form-widget card analysis-dashboard-widget mb-3"
                data-widget-id="feedback_form_analysis" data-feedback-id="{{id}}" data-widget-type="diverging_bar"
                role="region" aria-label="{{name}}">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="fa fa-poll-h mr-2" aria-hidden="true"></i>
                        {{name}}
                    </h5>
                    {{#has_comments}}
                    <ul class="nav nav-pills feedback-nav mb-0" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" href="#" data-toggle-view="chart" role="tab"
                                aria-selected="true">
                                <i class="fa fa-chart-bar mr-1"></i>{{#str}}chart_view, local_analysis_dashboard{{/str}}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" data-toggle-view="comments" role="tab" aria-selected="false">
                                <i class="fa fa-comment mr-1"></i>{{#str}}comments_view,
                                local_analysis_dashboard{{/str}}
                            </a>
                        </li>
                    </ul>
                    {{/has_comments}}
                </div>
                <div class="card-body widget-body" aria-live="polite" aria-busy="true">
                    <div class="widget-loading" data-region="widget-loading" role="status">
                        <div class="d-flex justify-content-center align-items-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="sr-only">{{#str}}loading, local_analysis_dashboard{{/str}}</span>
                            </div>
                        </div>
                    </div>
                    <div class="widget-content" data-region="widget-content" style="display: none;">
                    </div>
                    <div class="widget-comments" data-region="widget-comments" style="display: none;">
                    </div>
                    <div class="widget-error" data-region="widget-error" style="display: none;" role="alert">
                        <div class="alert alert-danger mb-0">
                            <i class="fa fa-exclamation-triangle mr-1" aria-hidden="true"></i>
                            {{#str}}widget_error, local_analysis_dashboard{{/str}}
                        </div>
                    </div>
                    <div class="widget-nodata" data-region="widget-nodata" style="display: none;">
                        <div class="text-center text-muted py-4">
                            <i class="fa fa-info-circle fa-2x mb-2 d-block" aria-hidden="true"></i>
                            {{#str}}widget_no_data, local_analysis_dashboard{{/str}}
                        </div>
                    </div>
                </div>
            </div>
            {{/feedback_forms}}
        </div>
    </div>
    {{/has_feedback_forms}}

    {{^has_feedback_forms}}
    <div class="alert alert-info">
        {{#str}}no_feedback_activities, local_analysis_dashboard{{/str}}
    </div>
    {{/has_feedback_forms}}
    {{/tab_feedback_active}}
</div>

{{#js}}
require(['local_analysis_dashboard/course_dashboard', 'local_analysis_dashboard/feedback_export'],
function(CourseDashboard, FeedbackExport) {
CourseDashboard.init({{{widgets_json}}}, {{courseid}}, {{{feedback_forms_json}}});
{{#tab_feedback_active}}
FeedbackExport.init({{{feedback_forms_json}}}, {{courseid}}, '{{courseshortname}}');
{{/tab_feedback_active}}
});
{{/js}}