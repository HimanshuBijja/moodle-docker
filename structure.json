{
  "dashboard": {
    "admin": [
      {
        "type": "pie",
        "title": "Site Activity Overview",
        "data": [
          "Enrolments",
          "Activities",
          "Activity Completion",
          "Guest Visits"
        ]
      },
      {
        "type": "pie",
        "title": "Users Registration Stats",
        "data": ["Success", "Suspended", "Pending", "Deleted"]
      },
      {
        "type": "pie",
        "title": "Course Information",
        "data": ["Name", "Registration Count"]
      },
      {
        "type": "bar",
        "title": "Registered Users Enrolment Status",
        "data": [
          "Not enrolled",
          "Enrolled in more than one course",
          "Enrolled in only one course"
        ]
      },
      {
        "type": "bar",
        "title": "Enrolled Methods",
        "data": ["Manual", "Guest", "Secure OTP"]
      },
      {
        "type": "line",
        "title": "Site Visits Over Time",
        "data": ["Daily visits", "Weekly visits", "Monthly visits"]
      },
      {
        "type": "counter",
        "title": "Total Users",
        "data": ["Active users", "Suspended users", "Deleted users"]
      },
      {
        "type": "counter",
        "title": "Total Courses",
        "data": ["Visible courses", "Hidden courses", "Total categories"]
      },
      {
        "type": "bar",
        "title": "Active Users",
        "data": [
          "Logged in last 7 days",
          "Logged in last 30 days",
          "Never logged in"
        ]
      },
      {
        "type": "pie",
        "title": "Disk Usage",
        "data": ["Moodledata size", "Database size", "Backup files size"]
      },
      {
        "type": "bar",
        "title": "Authentication Report",
        "data": ["Manual logins", "OAuth logins", "Failed login attempts"]
      },
      {
        "type": "gauge",
        "title": "Server Performance",
        "data": ["CPU usage", "RAM usage", "Disk I/O"]
      },
      {
        "type": "table",
        "title": "Course Categories Overview",
        "data": ["Category name", "Course count", "Enrolment count"]
      },
      {
        "type": "bar",
        "title": "Users by Working Location",
        "source": "auth_secureotp_userdata.working_location",
        "data": ["Location name", "User count"]
      },
      {
        "type": "pie",
        "title": "Employee Type Distribution",
        "source": "auth_secureotp_userdata.employee_type",
        "data": ["CIVIL", "POLICE", "Other"]
      },
      {
        "type": "bar",
        "title": "Users by Current Rank",
        "source": "auth_secureotp_userdata.current_rank",
        "data": ["Rank", "User count"]
      },
      {
        "type": "bar",
        "title": "Users by Unit / Department",
        "source": "auth_secureotp_userdata.unit_name",
        "data": ["Unit name", "User count"]
      },
      {
        "type": "bar",
        "title": "Users by CP/SP Office",
        "source": "auth_secureotp_userdata.cp_sp_office",
        "data": ["CP/SP Office", "User count"]
      },
      {
        "type": "pie",
        "title": "Users by Gender",
        "source": "auth_secureotp_userdata.gender",
        "data": ["Male", "Female", "Other"]
      },
      {
        "type": "pie",
        "title": "Users by Education Category",
        "source": "auth_secureotp_userdata.education_category",
        "data": ["Category", "User count"]
      },
      {
        "type": "bar",
        "title": "Users by City",
        "source": "auth_secureotp_userdata.city",
        "data": ["City", "User count"]
      },
      {
        "type": "pie",
        "title": "SecureOTP Account Security Status",
        "source": "auth_secureotp_security.status",
        "data": ["PROVISIONED", "ACTIVE", "SUSPENDED", "ARCHIVED"]
      },
      {
        "type": "counter",
        "title": "SecureOTP Security Summary",
        "source": "auth_secureotp_security",
        "data": [
          "Locked accounts",
          "OTP-enabled users",
          "Password-enabled users",
          "Total failed attempts today"
        ]
      },
      {
        "type": "line",
        "title": "OTP Authentication Events Over Time",
        "source": "auth_secureotp_audit",
        "data": ["OTP_SENT", "OTP_VERIFIED", "LOGIN_SUCCESS", "LOGIN_FAILED"]
      },
      {
        "type": "bar",
        "title": "Audit Events by Severity",
        "source": "auth_secureotp_audit.severity",
        "data": ["INFO", "WARNING", "CRITICAL"]
      },
      {
        "type": "table",
        "title": "Recent Failed Login Attempts",
        "source": "auth_secureotp_audit",
        "data": [
          "Employee ID",
          "IP address",
          "User agent",
          "Timestamp",
          "Event status"
        ]
      },
      {
        "type": "bar",
        "title": "Failed Attempts by Working Location",
        "source": "auth_secureotp_audit + auth_secureotp_userdata",
        "data": ["Working location", "Failed attempt count"]
      },
      {
        "type": "table",
        "title": "Bulk Import History",
        "source": "auth_secureotp_import_log",
        "data": [
          "Batch ID",
          "Source system",
          "Total records",
          "Success count",
          "Failed count",
          "Status",
          "Duration"
        ]
      },
      {
        "type": "pie",
        "title": "Users by Source System",
        "source": "auth_secureotp_userdata.source_system",
        "data": ["HR_MASTER", "STUDENT_DB", "Other"]
      },
      {
        "type": "bar",
        "title": "Rate Limit Hits",
        "source": "auth_secureotp_rate_limit",
        "data": ["OTP_REQUEST", "OTP_VERIFY", "LOGIN_ATTEMPT"]
      }
    ],

